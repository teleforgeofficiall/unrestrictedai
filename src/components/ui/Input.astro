---
export interface Props {
  type?: string;
  placeholder?: string;
  value?: string;
  name?: string;
  required?: boolean;
  disabled?: boolean;
  class?: string;
  label?: string;
  description?: string;
  error?: string;
}

const { type = 'text', label, description, error, ...inputProps } = Astro.props;

const inputClasses = 'w-full px-4 py-3 bg-background border border-border rounded-2xl text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-ring focus:border-transparent transition-all duration-200 disabled:opacity-50 disabled:cursor-not-allowed text-base';
---

<div class="space-y-2">
  {label && <label class="text-sm font-medium text-foreground">{label}</label>}
  {description && <p class="text-sm text-muted-foreground">{description}</p>}
  <input
    type={type}
    {...inputProps}
    class:list={[inputClasses, error && 'border-destructive focus:ring-destructive', Astro.props.class]}
  />
  {error && <p class="text-sm text-destructive">{error}</p>}
</div>
