---
import Card from '../ui/Card.astro';

const features = [
  {
    title: 'Unrestricted Creation',
    description: 'Generate any image you can imagine with no content restrictions or creative limits.',
    icon: 'sparkles',
  },
  {
    title: 'Anonymous & Private',
    description: 'No account needed. Your prompts and images stay private on your device.',
    icon: 'lock',
  },
  {
    title: 'Multiple Styles',
    description: 'Choose from 8+ art styles including realistic, anime, cyberpunk, and more.',
    icon: 'palette',
  },
  {
    title: 'Lightning Fast',
    description: 'Get your images in seconds with our optimized generation pipeline.',
    icon: 'zap',
  },
  {
    title: 'Commercial Rights',
    description: 'You own all generated images. Use them anywhere, even commercially.',
    icon: 'check-circle',
  },
  {
    title: 'Aspect Ratio Control',
    description: 'Generate in any format: square, landscape, portrait, and more.',
    icon: 'crop',
  },
];

const icons: Record<string, string> = {
  sparkles: 'M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 0 0-2.455 2.456ZM16.894 20.567 16.5 21.75l-.394-1.183a2.25 2.25 0 0 0-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 0 0 1.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 0 0 1.423 1.423l1.183.394-1.183.394a2.25 2.25 0 0 0-1.423 1.423Z',
  lock: 'M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z',
  palette: 'M9.53 16.122a3 3 0 0 0-5.78 1.128 2.25 2.25 0 0 0 2.4 2.245 4.5 4.5 0 0 0 8.4-2.245c0-.399-.078-.78-.22-1.128m0 0a15.998 15.998 0 0 0 3.388-1.62m-5.043-.025a15.994 15.994 0 0 1 1.622-3.395m3.42 3.42a15.995 15.995 0 0 0 4.764-4.648l3.876-5.814a1.151 1.151 0 0 0-1.597-1.597L14.146 6.32a15.996 15.996 0 0 0-4.649 4.763m3.42 3.42a6.776 6.776 0 0 0-3.42-3.42',
  zap: 'm3.75 13.5 10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z',
  'check-circle': 'M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z',
  crop: 'M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25H12',
};
---

<section id="features" class="py-16 md:py-24">
  <div class="mx-auto max-w-[1400px] px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12 sm:mb-16">
      <h2 class="text-2xl sm:text-5xl font-bold tracking-tight text-balance mb-4">
        Why Choose Our Generator
      </h2>
      <p class="text-base sm:text-lg text-muted-foreground max-w-2xl mx-auto">
        Premium AI image generation with zero restrictions. Everything you need to bring your ideas to life.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6">
      {features.map((feature) => (
        <Card key={feature.title}>
          <div class="w-10 h-10 rounded-2xl bg-brand/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d={icons[feature.icon]} />
            </svg>
          </div>
          <h3 class="text-lg font-semibold mb-2">{feature.title}</h3>
          <p class="text-sm text-muted-foreground">{feature.description}</p>
        </Card>
      ))}
    </div>
  </div>
</section>
