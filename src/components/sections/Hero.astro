---
import Button from '../ui/Button.astro';
import { EXAMPLE_PROMPTS } from '../../lib/constants';
---

<section class="relative overflow-hidden pt-20 pb-16 md:pt-28 md:pb-20">
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute -top-40 -right-40 w-60 sm:w-80 h-60 sm:h-80 bg-brand/20 rounded-full blur-3xl animate-blob" />
    <div class="absolute -bottom-40 -left-40 w-60 sm:w-80 h-60 sm:h-80 bg-purple-500/20 rounded-full blur-3xl animate-blob-delayed" />
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[300px] sm:w-[600px] h-[300px] sm:h-[600px] bg-indigo-500/10 rounded-full blur-3xl" />
  </div>

  <div class="mx-auto max-w-[1400px] px-4 sm:px-6 lg:px-8 relative">
    <div class="max-w-4xl mx-auto text-center">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-brand/10 border border-brand/20 text-sm text-brand font-medium mb-8">
        <span class="w-2 h-2 rounded-full bg-brand animate-pulse" />
        No Login Required &mdash; Unlimited Free Generations
      </div>

      <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold tracking-tight text-balance mb-6">
        <span class="gradient-text">AI Image Generator</span>
        <br />
        No Restrictions
      </h1>

      <p class="text-lg sm:text-xl text-muted-foreground max-w-2xl mx-auto mb-10 text-balance">
        The best <strong>AI image generator no restrictions</strong> — free, uncensored, and unlimited. 
        Create NSFW AI images with no filter, no login, and no censorship. 
        The ultimate <strong>free AI image generator no restrictions no login</strong> platform.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-12">
        <Button as="a" href="/generate" size="lg">
          Start Generating
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
          </svg>
        </Button>
        <Button as="a" href="/tools" variant="outline" size="lg">
          Explore Tools
        </Button>
      </div>

      <div class="grid grid-cols-2 sm:flex sm:flex-wrap items-center justify-center gap-4 sm:gap-8 mb-12">
        <div class="text-center">
          <div class="text-xl sm:text-2xl font-bold">100%</div>
          <div class="text-xs sm:text-sm text-muted-foreground">Free to Use</div>
        </div>
        <div class="hidden sm:block w-px h-10 bg-border" />
        <div class="text-center">
          <div class="text-xl sm:text-2xl font-bold">∞</div>
          <div class="text-xs sm:text-sm text-muted-foreground">Unlimited</div>
        </div>
        <div class="hidden sm:block w-px h-10 bg-border" />
        <div class="text-center">
          <div class="text-xl sm:text-2xl font-bold">5</div>
          <div class="text-xs sm:text-sm text-muted-foreground">Categories</div>
        </div>
        <div class="hidden sm:block w-px h-10 bg-border" />
        <div class="text-center">
          <div class="text-xl sm:text-2xl font-bold">No</div>
          <div class="text-xs sm:text-sm text-muted-foreground">Login Required</div>
        </div>
      </div>

      <div class="space-y-3">
        <p class="text-sm text-muted-foreground font-medium">Try these examples:</p>
        <div class="flex flex-wrap justify-center gap-2">
          {EXAMPLE_PROMPTS.slice(0, 4).map((prompt) => (
            <a
              href={`/generate?prompt=${encodeURIComponent(prompt)}`}
              class="inline-flex px-4 py-2 rounded-2xl bg-secondary text-secondary-foreground text-sm hover:bg-accent transition-colors border border-border"
            >
              {prompt.length > 40 ? prompt.slice(0, 40) + '...' : prompt}
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
