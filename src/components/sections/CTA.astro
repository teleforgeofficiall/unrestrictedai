---
import Button from '../ui/Button.astro';
---

<section class="py-16 md:py-24">
  <div class="mx-auto max-w-[1400px] px-4 sm:px-6 lg:px-8">
    <div class="relative overflow-hidden rounded-2xl sm:rounded-3xl bg-gradient-to-br from-brand via-purple-600 to-indigo-600 px-6 sm:px-16 py-12 sm:py-20 text-center">
      <div class="absolute inset-0 overflow-hidden pointer-events-none">
        <div class="absolute -top-20 -right-20 w-40 sm:w-60 h-40 sm:h-60 bg-white/10 rounded-full blur-3xl" />
        <div class="absolute -bottom-20 -left-20 w-40 sm:w-60 h-40 sm:h-60 bg-white/10 rounded-full blur-3xl" />
      </div>

      <div class="relative">
        <h2 class="text-2xl sm:text-5xl font-bold tracking-tight text-white text-balance mb-4">
          Start Creating Unrestricted AI Art
        </h2>
        <p class="text-base sm:text-lg text-white/80 max-w-2xl mx-auto mb-8 text-balance">
          No login. No limits. No censorship. Generate stunning images right now.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <Button as="a" href="/generate" size="lg" class="bg-white text-brand hover:bg-white/90 shadow-lg hover:shadow-xl border-0">
            Generate Free Images
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
            </svg>
          </Button>
          <Button as="a" href="/tools" variant="ghost" size="lg" class="text-white hover:bg-white/10 border border-white/20">
            View All Tools
          </Button>
        </div>
      </div>
    </div>
  </div>
</section>
