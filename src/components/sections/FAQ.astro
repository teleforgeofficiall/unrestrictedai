---
import { FAQ_ITEMS } from '../../lib/constants';
import { SITE } from '../../lib/constants';
---

<section id="faq" class="py-16 md:py-24">
  <div class="mx-auto max-w-[1400px] px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl mx-auto">
      <div class="text-center mb-12 sm:mb-16">
        <h2 class="text-2xl sm:text-5xl font-bold tracking-tight text-balance mb-4">
          Frequently Asked Questions
        </h2>
        <p class="text-base sm:text-lg text-muted-foreground">
          Everything you need to know about our AI image generator.
        </p>
      </div>

      <div class="space-y-3">
        {FAQ_ITEMS.map((item) => (
          <details class="group rounded-2xl border border-border bg-card overflow-hidden transition-all duration-200 open:shadow-sm">
            <summary class="flex items-center justify-between p-5 cursor-pointer text-base font-medium hover:bg-muted/50 transition-colors [&::-webkit-details-marker]:hidden">
              {item.question}
              <svg class="w-5 h-5 text-muted-foreground shrink-0 transition-transform duration-200 group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5"/>
              </svg>
            </summary>
            <div class="px-5 pb-5 text-sm text-muted-foreground leading-relaxed">
              {item.answer}
            </div>
          </details>
        ))}
      </div>
    </div>
  </div>
</section>

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": FAQ_ITEMS.map((item) => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer,
    },
  })),
})} />