---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import NativeBanner from '../components/ads/NativeBanner.astro';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Contact', url: '/contact' },
];
---

<BaseLayout
  title="Contact Us - AI Image Generator No Restrictions Support"
  description="Get in touch with our team about the best free AI image generator no restrictions. We are here to help with your uncensored AI image generation needs."
>
  <div class="mx-auto max-w-[1400px] px-4 sm:px-6 lg:px-8 py-8 md:py-12">
    <div class="max-w-3xl mx-auto">
      <Breadcrumbs items={breadcrumbs} />

      <div class="text-center mb-12">
        <h1 class="text-3xl sm:text-5xl font-bold tracking-tight text-balance mb-4">
          Contact <span class="gradient-text">Us</span>
        </h1>
        <p class="text-base sm:text-lg text-muted-foreground">
          Have questions, suggestions, or feedback about our AI image generator no restrictions? We would love to hear from you.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
        <div class="space-y-6">
          <div class="rounded-3xl border border-border bg-card p-6">
            <h2 class="text-lg font-semibold text-foreground mb-2">Email Us</h2>
            <p class="text-sm text-muted-foreground">Send us an email anytime and we will respond as soon as possible.</p>
            <a href="mailto:support@unrestrictedai.vercel.app" class="inline-block mt-3 text-brand hover:underline font-medium">
              support@unrestrictedai.vercel.app
            </a>
          </div>
          <div class="rounded-3xl border border-border bg-card p-6">
            <h2 class="text-lg font-semibold text-foreground mb-2">Response Time</h2>
            <p class="text-sm text-muted-foreground">We typically respond within 24-48 hours on business days. For urgent matters, please include "URGENT" in your subject line.</p>
          </div>
          <div class="rounded-3xl border border-border bg-card p-6">
            <h2 class="text-lg font-semibold text-foreground mb-2">Common Topics</h2>
            <ul class="space-y-1.5 text-sm text-muted-foreground">
              <li>• Technical support and troubleshooting</li>
              <li>• Feature requests and suggestions</li>
              <li>• Content or policy questions</li>
              <li>• Partnership or collaboration inquiries</li>
              <li>• Bug reports and feedback</li>
            </ul>
          </div>
        </div>

        <div>
          <form class="space-y-5" method="POST" action="/contact">
            <div class="space-y-2">
              <label for="name" class="text-sm font-medium">Name</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                placeholder="Your name"
                class="w-full px-4 py-3 bg-background border border-border rounded-2xl text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-ring focus:border-transparent text-base transition-all duration-200"
              />
            </div>
            <div class="space-y-2">
              <label for="email" class="text-sm font-medium">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                placeholder="your@email.com"
                class="w-full px-4 py-3 bg-background border border-border rounded-2xl text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-ring focus:border-transparent text-base transition-all duration-200"
              />
            </div>
            <div class="space-y-2">
              <label for="subject" class="text-sm font-medium">Subject</label>
              <input
                type="text"
                id="subject"
                name="subject"
                required
                placeholder="What is this about?"
                class="w-full px-4 py-3 bg-background border border-border rounded-2xl text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-ring focus:border-transparent text-base transition-all duration-200"
              />
            </div>
            <div class="space-y-2">
              <label for="message" class="text-sm font-medium">Message</label>
              <textarea
                id="message"
                name="message"
                required
                rows={6}
                placeholder="Tell us more about your inquiry..."
                class="w-full px-4 py-3 bg-background border border-border rounded-2xl text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-ring focus:border-transparent text-base resize-none transition-all duration-200"
              />
            </div>
            <button
              type="submit"
              class="w-full px-6 sm:px-8 py-3.5 sm:py-4 bg-brand text-white font-semibold rounded-2xl hover:opacity-90 transition-all duration-200 shadow-sm hover:shadow-md text-base sm:text-lg"
            >
              Send Message
            </button>
          </form>
        </div>
      </div>

      <NativeBanner />
    </div>
  </div>
</BaseLayout>
