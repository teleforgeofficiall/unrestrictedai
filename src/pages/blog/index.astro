---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Card from '../../components/ui/Card.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', ({ data }) => !data.draft);
posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const categories = [...new Set(posts.map((p) => p.data.category))];
const allTags = [...new Set(posts.flatMap((p) => p.data.tags))];
---

<BaseLayout
  title="AI Image Generation Blog - Tips for Unrestricted NSFW AI Art"
  description="Learn AI image generation tips, NSFW prompt engineering, and how to use an AI image generator no restrictions. Expert guides for uncensored AI art creation."
>
  <div class="mx-auto max-w-[1400px] px-4 sm:px-6 lg:px-8 py-8 md:py-12">
    <div class="text-center mb-16">
      <h1 class="text-3xl sm:text-5xl font-bold tracking-tight text-balance mb-4">
          <span class="gradient-text">Blog</span>
        </h1>
        <p class="text-base sm:text-lg text-muted-foreground max-w-2xl mx-auto">
        Expert guides, tips, and insights about AI image generation and creative technology.
      </p>
    </div>

    <div class="flex flex-wrap gap-2 mb-10 justify-center">
      <a
        href="/blog"
        class="px-4 py-2 rounded-2xl bg-brand text-white text-sm font-medium"
      >
        All Posts
      </a>
      {categories.map((category) => (
        <a
          href={`/blog?category=${category.toLowerCase()}`}
          class="px-4 py-2 rounded-2xl bg-secondary text-secondary-foreground text-sm font-medium hover:bg-accent transition-colors"
        >
          {category}
        </a>
      ))}
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {posts.map((post) => (
        <Card as="a" href={`/blog/${post.slug}`}>
          {post.data.image && (
            <div class="aspect-video rounded-2xl overflow-hidden mb-4 bg-gradient-to-br from-brand/5 to-purple-500/5">
              <img src={post.data.image} alt={post.data.title} class="w-full h-full object-cover" loading="lazy" />
            </div>
          )}
          <div class="flex items-center gap-2 mb-3">
            <span class="text-xs px-2 py-0.5 rounded-lg bg-brand/10 text-brand font-medium">
              {post.data.category}
            </span>
            <span class="text-xs text-muted-foreground">
              {new Date(post.data.date).toLocaleDateString('en-US', {
                month: 'short',
                day: 'numeric',
                year: 'numeric',
              })}
            </span>
          </div>
          <h2 class="text-lg font-semibold mb-2 line-clamp-2">{post.data.title}</h2>
          <p class="text-sm text-muted-foreground line-clamp-3">{post.data.description}</p>
          <div class="flex flex-wrap gap-1.5 mt-4">
            {post.data.tags.slice(0, 3).map((tag) => (
              <span class="text-xs px-2 py-0.5 rounded-lg bg-secondary text-secondary-foreground">
                #{tag}
              </span>
            ))}
          </div>
        </Card>
      ))}
    </div>

    {posts.length === 0 && (
      <div class="text-center py-20">
        <p class="text-muted-foreground">No blog posts yet. Check back soon!</p>
      </div>
    )}
  </div>
</BaseLayout>
