---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 - Page Not Found" noIndex>
  <div class="min-h-[70vh] flex items-center justify-center">
    <div class="text-center max-w-md mx-auto px-4">
      <div class="w-20 h-20 rounded-2xl bg-brand/10 flex items-center justify-center mx-auto mb-8">
        <svg class="w-10 h-10 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
        </svg>
      </div>

      <h1 class="text-6xl font-bold tracking-tight mb-4">404</h1>
      <p class="text-xl text-muted-foreground mb-8">
        This page doesn't exist.
      </p>
      <a
        href="/"
        class="inline-flex items-center px-6 py-3 bg-brand text-white font-semibold rounded-2xl hover:opacity-90 transition-all duration-200 shadow-sm hover:shadow-md gap-2"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18"/>
        </svg>
        Back to Home
      </a>
    </div>
  </div>
</BaseLayout>
