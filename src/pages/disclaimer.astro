---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Disclaimer', url: '/disclaimer' },
];
---

<BaseLayout
  title="Disclaimer - AI Image Generator No Restrictions"
  description="Legal disclaimer for our free AI image generator no restrictions. Important notices about using our uncensored NSFW AI image generator without filter."
>
  <div class="mx-auto max-w-[1400px] px-4 sm:px-6 lg:px-8 py-8 md:py-12">
    <div class="max-w-3xl mx-auto">
      <Breadcrumbs items={breadcrumbs} />

      <h1 class="text-3xl sm:text-5xl font-bold tracking-tight text-balance mb-6 sm:mb-8">
        Disclaimer
      </h1>

      <div class="space-y-5 sm:space-y-6 text-muted-foreground leading-relaxed">
        <p>Last updated: January 2026</p>

        <section>
          <h2 class="text-xl sm:text-2xl font-bold text-foreground mb-2 sm:mb-3">General Information</h2>
          <p>UnrestrictedAI provides AI image generation services for creative and informational purposes. The content generated by our AI models is based on the prompts provided by users.</p>
        </section>

        <section>
          <h2 class="text-2xl font-bold text-foreground mb-3">No Warranty</h2>
          <p>Our AI image generation service is provided without any warranty, express or implied. We do not guarantee that generated images will meet specific requirements or be error-free.</p>
        </section>

        <section>
          <h2 class="text-2xl font-bold text-foreground mb-3">User Responsibility</h2>
          <p>Users are solely responsible for the content they generate and how they use it. Users must ensure their use complies with applicable laws and regulations.</p>
        </section>

        <section>
          <h2 class="text-2xl font-bold text-foreground mb-3">AI Limitations</h2>
          <p>AI image generation may occasionally produce unexpected or inaccurate results. Generated content should not be used as factual or professional advice.</p>
        </section>

        <section>
          <h2 class="text-2xl font-bold text-foreground mb-3">Third-Party Content</h2>
          <p>Our service may use third-party AI models and APIs. We are not responsible for the output or actions of these third-party services.</p>
        </section>

        <section>
          <h2 class="text-2xl font-bold text-foreground mb-3">Contact</h2>
          <p>For questions about this disclaimer, visit our <a href="/contact" class="text-brand hover:underline">Contact page</a>.</p>
        </section>
      </div>
    </div>
  </div>
</BaseLayout>
